{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "lint": "npx nx run-many --target=lint",
    "lint:fix": "npx nx run-many --target=lint --fix",
    "dev:v0": "npx nx dev la-bidder-v0",
    "seed:clean": "docker exec la-bidder-postgres psql -U labidder -d labidder -c \"TRUNCATE items, bids CASCADE;\"",
    "seed": "npx nx seed la-bidder-api",
    "prepare": "husky",
    "swagger:generate": "ts-node -P apps/la-bidder-api/tsconfig.app.json -r tsconfig-paths/register scripts/generate-swagger.ts",
    "swagger:watch": "nodemon --watch apps/la-bidder-api/src -e ts,json --exec \"npm run swagger:generate\""
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/eslint": "22.6.4",
    "@nx/eslint-plugin": "22.6.4",
    "@nx/jest": "22.6.4",
    "@nx/js": "22.6.4",
    "@nx/nest": "^22.6.2",
    "@nx/next": "^22.6.4",
    "@nx/vite": "^22.6.4",
    "@nx/web": "22.6.4",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/ui": "~4.1.0",
    "autoprefixer": "10.4.13",
    "babel-jest": "^30.0.2",
    "eslint": "^9.8.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.0.2",
    "jest-util": "^30.0.2",
    "jiti": "2.4.2",
    "lint-staged": "^16.4.0",
    "nx": "22.6.2",
    "postcss": "8.4.38",
    "prettier": "^2.6.2",
    "tailwindcss": "3.4.3",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vitest": "~4.1.0",
    "webpack-cli": "^5.1.4"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "@nestjs/config": "^4.0.3",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.18",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "next": "~16.1.6",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "typeorm": "^0.3.28"
  },
  "lint-staged": {
    "*.{js,json,ts,html,css,scss,tsx,jsx}": [
      "prettier --write"
    ],
    "*.{js,ts,html,tsx,jsx}": [
      "eslint --max-warnings=1"
    ]
  }
}
